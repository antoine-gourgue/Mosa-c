# Copy to .env.production on the server and fill in the values.
# Used by docker-compose.prod.yml (the app and migrate services).

# --- Database (Postgres container in the compose) ---
# The DB host is the "postgres" service name from docker-compose.prod.yml.
POSTGRES_USER="mosaic"
POSTGRES_PASSWORD=""
POSTGRES_DB="mosaic"
# Build DATABASE_URL from the values above, e.g. (no leading/trailing spaces):
#   postgresql://POSTGRES_USER:POSTGRES_PASSWORD@postgres:5432/POSTGRES_DB?schema=public
DATABASE_URL=""

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="<RANDOM_SECRET>"
# Canonical public URL of the deployment.
AUTH_URL="https://your-domain.com"
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# --- Image storage: Supabase ---
STORAGE_DRIVER="supabase"
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<SUPABASE_SERVICE_ROLE_KEY>"
SUPABASE_STORAGE_BUCKET="pins"

# --- Optional OAuth providers (leave blank to disable) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# --- App port published on the host ---
APP_PORT="3000"
