generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  FEMALE
  MALE
  NON_BINARY
  UNDISCLOSED
}

enum NotificationType {
  FOLLOW
  LIKE
  COMMENT
}

enum BoardRole {
  OWNER
  EDITOR
  VIEWER
}

enum Role {
  USER
  ADMIN
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  username       String?   @unique
  bio            String?
  passwordHash   String?
  name           String
  avatarUrl      String?
  image          String?
  emailVerified  DateTime?
  gender         Gender?
  followersLabel String?
  verified       Boolean   @default(false)
  role           Role      @default(USER)
  disabled       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  pins      Pin[]     @relation("PinCreator")
  boards    Board[]
  saves     Save[]
  likes     Like[]
  comments  Comment[]
  following Follow[]  @relation("Follower")
  followers Follow[]  @relation("Creator")
  accounts  Account[]
  sessions  Session[]

  notifications      Notification[] @relation("NotificationRecipient")
  actedNotifications Notification[] @relation("NotificationActor")

  boardMemberships BoardMember[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Category {
  id       String @id @default(cuid())
  slug     String @unique
  label    String
  imageUrl String

  pins Pin[]
}

model Pin {
  id            String   @id @default(cuid())
  title         String
  description   String?
  imageUrl      String
  width         Int
  height        Int
  link          String?
  downloadCount Int      @default(0)
  createdAt     DateTime @default(now())

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  creatorId String
  creator   User   @relation("PinCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  saves     Save[]
  boardPins BoardPin[]
  likes     Like[]
  comments  Comment[]

  notifications Notification[]

  @@index([creatorId])
  @@index([categoryId])
}

model Like {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pinId     String
  pin       Pin      @relation(fields: [pinId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, pinId])
  @@index([pinId])
}

model Comment {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())

  pinId String
  pin   Pin    @relation(fields: [pinId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  notifications Notification[]

  @@index([pinId])
  @@index([authorId])
}

model Board {
  id        String   @id @default(cuid())
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  pins    BoardPin[]
  members BoardMember[]

  @@index([ownerId])
}

model BoardMember {
  boardId   String
  board     Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      BoardRole @default(EDITOR)
  createdAt DateTime  @default(now())

  @@id([boardId, userId])
  @@index([userId])
}

model BoardPin {
  boardId String
  board   Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  pinId   String
  pin     Pin      @relation(fields: [pinId], references: [id], onDelete: Cascade)
  addedAt DateTime @default(now())

  @@id([boardId, pinId])
  @@index([pinId])
}

model Save {
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pinId   String
  pin     Pin      @relation(fields: [pinId], references: [id], onDelete: Cascade)
  savedAt DateTime @default(now())

  @@id([userId, pinId])
  @@index([pinId])
}

model Follow {
  followerId String
  follower   User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  creatorId  String
  creator    User     @relation("Creator", fields: [creatorId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([followerId, creatorId])
  @@index([creatorId])
}

model Notification {
  id   String           @id @default(cuid())
  type NotificationType
  read Boolean          @default(false)

  recipientId String
  recipient   User   @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  actorId String
  actor   User   @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)

  pinId String?
  pin   Pin?    @relation(fields: [pinId], references: [id], onDelete: Cascade)

  commentId String?
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([recipientId, read])
  @@index([recipientId, createdAt])
}
