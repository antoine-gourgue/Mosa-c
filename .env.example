# Copy to .env and fill in the values. See src/lib/env.ts for validation.

# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://mosaic:mosaic@localhost:5432/mosaic?schema=public"

# PostgreSQL container credentials (used by docker-compose.yml).
POSTGRES_USER="mosaic"
POSTGRES_PASSWORD="mosaic"
POSTGRES_DB="mosaic"
POSTGRES_PORT="5432"

# Auth.js session secret. Generate one with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"

# Canonical URL of the deployment (optional in development).
AUTH_URL="http://localhost:3000"

# Google OAuth credentials (optional; the provider is enabled only when both are set).
# Create them at https://console.cloud.google.com/apis/credentials and set the
# authorized redirect URI to: <AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Image storage driver: "local" writes to public/uploads, "supabase" uploads to
# a public Supabase Storage bucket.
STORAGE_DRIVER="local"

# Supabase storage (only needed when STORAGE_DRIVER="supabase").
# SUPABASE_URL is the project URL, e.g. https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY is the service role key (server-side only, keep secret).
# SUPABASE_STORAGE_BUCKET is the public bucket name (default "pins").
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="pins"

# Umami analytics (optional; the script loads only when both are set).
# UMAMI_SRC is the tracker script URL, e.g. https://umami.example.com/script.js
UMAMI_SRC=""
UMAMI_WEBSITE_ID=""

# Public base URL exposed to the browser (optional).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Realtime (socket.io) service URL exposed to the browser.
# Dev: point it at the local realtime server. Prod: leave empty and proxy
# /socket.io to the realtime container on the same origin.
NEXT_PUBLIC_REALTIME_URL="http://localhost:4001"

# Optional: free Giphy API key to enable the GIF picker in messages.
# Get one at https://developers.giphy.com — leave empty to disable GIFs (no cost).
GIPHY_API_KEY=""
