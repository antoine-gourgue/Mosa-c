# Copy to .env and fill in the values. See src/lib/env.ts for validation.

# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://mosaic:mosaic@localhost:5432/mosaic?schema=public"

# PostgreSQL container credentials (used by docker-compose.yml).
POSTGRES_USER="mosaic"
POSTGRES_PASSWORD="mosaic"
POSTGRES_DB="mosaic"
POSTGRES_PORT="5432"

# Auth.js session secret. Generate one with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"

# Canonical URL of the deployment (optional in development).
AUTH_URL="http://localhost:3000"

# Google OAuth credentials (optional). Create them at:
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Apple OAuth credentials (optional). Create them in the Apple Developer portal.
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# Image storage driver: "local" writes to public/uploads, "s3" uses object storage.
STORAGE_DRIVER="local"

# Public base URL exposed to the browser (optional).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
