# Copy to .env and fill in the values. See src/lib/env.ts for validation.

# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://mosaic:mosaic@localhost:5432/mosaic?schema=public"

# PostgreSQL container credentials (used by docker-compose.yml).
POSTGRES_USER="mosaic"
POSTGRES_PASSWORD="mosaic"
POSTGRES_DB="mosaic"
POSTGRES_PORT="5432"

# Auth.js session secret. Generate one with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"

# Canonical URL of the deployment (optional in development).
AUTH_URL="http://localhost:3000"

# Google OAuth credentials (optional; the provider is enabled only when both are set).
# Create them at https://console.cloud.google.com/apis/credentials and set the
# authorized redirect URI to: <AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Image storage driver: "local" writes to public/uploads, "supabase" uploads to
# a public Supabase Storage bucket.
STORAGE_DRIVER="local"

# Supabase storage (only needed when STORAGE_DRIVER="supabase").
# SUPABASE_URL is the project URL, e.g. https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY is the service role key (server-side only, keep secret).
# SUPABASE_STORAGE_BUCKET is the public bucket name (default "pins").
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="pins"

# Umami analytics (optional; the script loads only when both are set).
# UMAMI_SRC is the tracker script URL, e.g. https://umami.example.com/script.js
UMAMI_SRC=""
UMAMI_WEBSITE_ID=""

# Public base URL exposed to the browser (optional).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Realtime (socket.io) service URL exposed to the browser.
# Dev: point it at the local realtime server. Prod: leave empty and proxy
# /socket.io to the realtime container on the same origin.
NEXT_PUBLIC_REALTIME_URL="http://localhost:4001"

# Server-to-server bridge so the web process can push notifications to a user's
# live sockets. REALTIME_INTERNAL_URL is the realtime service's internal origin
# (not exposed to the browser); REALTIME_INTERNAL_SECRET must match the value the
# realtime server is started with. Leave both empty to disable live notifications
# (they still persist and show on refresh).
REALTIME_INTERNAL_URL="http://localhost:4001"
REALTIME_INTERNAL_SECRET=""

# Web Push (VAPID). Generate a key pair with: npx web-push generate-vapid-keys
# The public key must be exposed to the browser as NEXT_PUBLIC_VAPID_PUBLIC_KEY
# (same value). VAPID_SUBJECT is a mailto: or https: contact. Leave empty to
# disable push notifications. APP_INTERNAL_URL is the web app's origin reachable
# from the realtime service (e.g. http://app:3000 in compose), so message pushes
# can be sent; it pairs with REALTIME_INTERNAL_SECRET above.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:notifications@example.com"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
APP_INTERNAL_URL="http://localhost:3000"

# Optional: free Giphy API key to enable the GIF picker in messages.
# Get one at https://developers.giphy.com — leave empty to disable GIFs (no cost).
GIPHY_API_KEY=""

# Optional: Mistral API key powering the AI features (image description, tag
# suggestions, embeddings). Free "Experiment" tier at https://console.mistral.ai
# — leave empty to disable AI cleanly (helpers no-op).
MISTRAL_API_KEY=""

# Optional: Cloudflare Workers AI powers "Generate with AI" in the create flow
# (FLUX.1 [schnell]) — a free daily allowance. Create a free account, copy your
# Account ID, and make an API token with the "Workers AI" permission. Leave both
# empty to hide the AI generation entry cleanly. https://dash.cloudflare.com
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_AI_TOKEN=""
# Optional: diffusion steps per image (1-8, default 3). Fewer steps = fewer
# Neurons spent and faster generation, at a small quality cost.
CLOUDFLARE_AI_STEPS=""

# Email (Resend) for account verification OTP. Leave empty in dev: codes are
# printed to the server console instead of being emailed (no external cost).
# Prod: create a key at https://resend.com and send from a verified subdomain.
RESEND_API_KEY=""
EMAIL_FROM="Mosaic <noreply@send.yourdomain.com>"
